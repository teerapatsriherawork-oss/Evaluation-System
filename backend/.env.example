# ===== Server =====
PORT=3000

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=personnel_eval

# ===== JWT =====
# ใช้ค่าสุ่มยาว ๆ เช่น `openssl rand -hex 32`
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# ===== Cookie (มิลลิวินาที, 86400000 = 24 ชม.) =====
COOKIE_MAX_AGE=86400000
